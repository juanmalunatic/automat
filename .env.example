# Core app config
AUTOMAT_APP_ENV=local
AUTOMAT_DB_PATH=data/automat.sqlite3
AUTOMAT_RUN_MODE=fake

# AI placeholders
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Upwork placeholders
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
UPWORK_ACCESS_TOKEN=
UPWORK_REFRESH_TOKEN=
UPWORK_GRAPHQL_URL=https://placeholder.invalid/upwork-graphql

# Search and ingestion
UPWORK_SEARCH_TERMS=WordPress,WooCommerce,PHP,custom plugin,Gravity Forms,LearnDash,ACF,WP-CLI,API,webhook,checkout,performance
UPWORK_POLL_LIMIT=50

# Optional runtime knobs
AUTOMAT_TARGET_RATE_USD=
AUTOMAT_CONNECT_COST_USD=
